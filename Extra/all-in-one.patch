diff --git a/filewatcher-ui/src/main/java/com/filewatcherui/ui/SettingsPanel.java b/filewatcher-ui/src/main/java/com/filewatcherui/ui/SettingsPanel.java
new file mode 100644
index 0000000..52aef73
--- /dev/null
+++ b/filewatcher-ui/src/main/java/com/filewatcherui/ui/SettingsPanel.java
@@ -0,0 +1,322 @@
+package com.filewatcherui.ui;
+
+import com.filewatcherui.service.ServiceClient;
+import com.google.gson.JsonObject;
+import javafx.application.Platform;
+import javafx.geometry.Insets;
+import javafx.geometry.Pos;
+import javafx.scene.control.*;
+import javafx.scene.layout.*;
+import javafx.scene.paint.Color;
+
+import java.util.logging.Logger;
+
+/**
+ * Settings tab: displays every AppConfig field as an editable control and
+ * persists changes via UPDATE_CONFIGURATION over the WebSocket.
+ *
+ * Population:   on tab focus (or connect) → client.getConfiguration() →
+ *               addConfigListener → populate()
+ * Persistence:  Save button → buildPatch() → client.sendUpdateConfig(patch)
+ *               → service persists to services.json + broadcasts new config
+ *               → addConfigListener fires again → fields re-populated with
+ *               the confirmed live values (round-trip confirmation).
+ *
+ * "Requires restart" fields are editable but shown with a ⚠ note so the
+ * operator knows the change won't take effect until the service is cycled.
+ * Hot-applied fields (logLevel, heartbeatIntervalSeconds, etc.) take effect
+ * immediately with no restart needed.
+ */
+public class SettingsPanel {
+
+    private static final Logger LOG = Logger.getLogger(SettingsPanel.class.getName());
+
+    // ── Field controls ────────────────────────────────────────────────────────
+
+    // WebSocket (restart-required)
+    private final TextField wsHostField    = styledField();
+    private final TextField wsPortField    = styledField();
+
+    // Polling / transfer
+    private final TextField defaultIntervalField = styledField();
+    private final CheckBox  pollingFallbackCheck = new CheckBox();
+    private final TextField maxTransfersField    = styledField();   // 0 = unbounded; restart-required
+
+    // Logging
+    private final ComboBox<String> logLevelCombo = new ComboBox<>();
+    private final TextField logMaxSizeField      = styledField();
+    private final TextField logMaxCountField     = styledField();
+
+    // Scheduler (restart-required)
+    private final TextField schedulerPoolField = styledField();
+
+    // Heartbeat (hot-applied)
+    private final TextField heartbeatField = styledField();
+
+    // SSH / SFTP (hot-applied)
+    private final TextField sshTimeoutField  = styledField();
+    private final TextField sftpTimeoutField = styledField();
+
+    // ── Status label / buttons ────────────────────────────────────────────────
+
+    private final Label  statusLabel  = new Label();
+    private final Button saveButton   = pillBtn("Save Changes", Theme.ACCENT);
+    private final Button reloadButton = pillBtn("Reload from Service", Theme.TEXT_SECONDARY);
+
+    // ── Root ──────────────────────────────────────────────────────────────────
+
+    private final ScrollPane root;
+    private final ServiceClient client;
+
+    public SettingsPanel(ServiceClient client) {
+        this.client = client;
+
+        logLevelCombo.getItems().addAll("SEVERE", "WARNING", "INFO", "FINE", "FINEST");
+        logLevelCombo.setValue("INFO");
+        logLevelCombo.setStyle(
+                "-fx-background-color: " + Theme.BG_CARD + ";" +
+                "-fx-text-fill: "        + Theme.TEXT_PRIMARY + ";" +
+                "-fx-border-color: "     + Theme.BORDER + ";" +
+                "-fx-border-radius: 4;" +
+                "-fx-background-radius: 4;");
+
+        pollingFallbackCheck.setStyle("-fx-text-fill: " + Theme.TEXT_PRIMARY + ";");
+
+        VBox content = new VBox(0);
+        content.setStyle("-fx-background-color: " + Theme.BG_BASE + ";");
+        content.setPadding(new Insets(24, 28, 28, 28));
+        content.setSpacing(0);
+
+        content.getChildren().addAll(
+                pageTitle("Service Configuration"),
+                subtitle("Changes marked ⚠ require a service restart to take effect."),
+                section("WebSocket"),
+                row("Bind host",          wsHostField,          "IP or hostname the WS server binds to  ⚠ restart required"),
+                row("Port",               wsPortField,          "Port number (default 9876)  ⚠ restart required"),
+                section("File Transfer"),
+                row("Default interval (s)", defaultIntervalField, "Polling/heartbeat interval used when a job has no per-job interval set"),
+                row("Polling fallback",   pollingFallbackCheck, "When disabled, jobs that can't use NIO or remote exec fail with ERROR rather than falling back to polling"),
+                row("Max concurrent transfers", maxTransfersField, "Thread pool size for file transfers; 0 = unbounded  ⚠ restart required"),
+                section("Logging"),
+                row("Log level",          logLevelCombo,        "SEVERE → FINEST. FINE/FINEST produce verbose output.  ✓ hot-applied"),
+                row("Max log file size (MB)", logMaxSizeField,  "Per rotating log file size ceiling"),
+                row("Max log file count", logMaxCountField,     "Number of rotating log files to retain"),
+                section("Scheduler"),
+                row("Thread pool size",   schedulerPoolField,   "Scheduled task thread count (polling, heartbeats)  ⚠ restart required"),
+                section("Heartbeat"),
+                row("Heartbeat interval (s)", heartbeatField,   "How often each running job's last-seen timestamp is updated; 0 = disabled  ✓ hot-applied"),
+                section("SSH / SFTP"),
+                row("SSH connect timeout (ms)",  sshTimeoutField,  "Milliseconds to wait when opening an SSH session  ✓ hot-applied"),
+                row("SFTP channel timeout (ms)", sftpTimeoutField, "Milliseconds to wait when opening an SFTP channel  ✓ hot-applied"),
+                buildActions()
+        );
+
+        root = new ScrollPane(content);
+        root.setFitToWidth(true);
+        root.setStyle("-fx-background-color: " + Theme.BG_BASE + "; -fx-background: " + Theme.BG_BASE + ";");
+
+        // Wire Save
+        saveButton.setOnAction(e -> save());
+
+        // Wire Reload
+        reloadButton.setOnAction(e -> {
+            statusLabel.setText("Reloading…");
+            statusLabel.setTextFill(Color.web(Theme.TEXT_MUTED));
+            client.getConfiguration();
+        });
+
+        // Wire config listener — receives both the initial GET reply and the
+        // round-trip confirmation after a successful UPDATE_CONFIGURATION.
+        client.addConfigListener(cfg -> Platform.runLater(() -> populate(cfg)));
+    }
+
+    public ScrollPane getRoot() { return root; }
+
+    /**
+     * Called by MainWindow when the Settings tab is selected to ensure the
+     * form shows live values even if the user navigated away and back.
+     */
+    public void requestRefresh() {
+        client.getConfiguration();
+    }
+
+    // ── Populate fields from config JSON ──────────────────────────────────────
+
+    private void populate(JsonObject cfg) {
+        if (cfg == null) return;
+
+        setField(wsHostField,         cfg, "websocketHost",          "localhost");
+        setField(wsPortField,         cfg, "websocketPort",          "9876");
+        setField(defaultIntervalField,cfg, "defaultIntervalSeconds", "120");
+        setField(maxTransfersField,   cfg, "maxConcurrentTransfers", "0");
+        setField(logMaxSizeField,     cfg, "logMaxFileSizeMb",       "10");
+        setField(logMaxCountField,    cfg, "logMaxFileCount",        "5");
+        setField(schedulerPoolField,  cfg, "schedulerThreadPoolSize","4");
+        setField(heartbeatField,      cfg, "heartbeatIntervalSeconds","60");
+        setField(sshTimeoutField,     cfg, "sshConnectTimeoutMs",    "10000");
+        setField(sftpTimeoutField,    cfg, "sftpChannelTimeoutMs",   "5000");
+
+        if (cfg.has("pollingFallbackEnabled"))
+            pollingFallbackCheck.setSelected(cfg.get("pollingFallbackEnabled").getAsBoolean());
+
+        if (cfg.has("logLevel")) {
+            String lvl = cfg.get("logLevel").getAsString().toUpperCase();
+            if (logLevelCombo.getItems().contains(lvl)) logLevelCombo.setValue(lvl);
+        }
+
+        statusLabel.setText("Loaded from service.");
+        statusLabel.setTextFill(Color.web(Theme.TEXT_MUTED));
+    }
+
+    private void setField(TextField f, JsonObject cfg, String key, String fallback) {
+        f.setText(cfg.has(key) ? cfg.get(key).getAsString() : fallback);
+    }
+
+    // ── Save ──────────────────────────────────────────────────────────────────
+
+    private void save() {
+        try {
+            JsonObject patch = buildPatch();
+            client.sendUpdateConfig(patch);
+            statusLabel.setText("Saved — waiting for confirmation…");
+            statusLabel.setTextFill(Color.web(Theme.SUCCESS));
+        } catch (IllegalArgumentException ex) {
+            statusLabel.setText("Validation error: " + ex.getMessage());
+            statusLabel.setTextFill(Color.web(Theme.DANGER));
+        }
+    }
+
+    private JsonObject buildPatch() {
+        JsonObject patch = new JsonObject();
+
+        String wsHost = wsHostField.getText().trim();
+        if (!wsHost.isBlank()) patch.addProperty("websocketHost", wsHost);
+
+        patch.addProperty("websocketPort",          parseInt(wsPortField, "WebSocket port", 1, 65535));
+        patch.addProperty("defaultIntervalSeconds", parseInt(defaultIntervalField, "Default interval", 1, 86400));
+        patch.addProperty("pollingFallbackEnabled", pollingFallbackCheck.isSelected());
+        patch.addProperty("maxConcurrentTransfers", parseInt(maxTransfersField, "Max concurrent transfers", 0, 1000));
+        patch.addProperty("logLevel",               logLevelCombo.getValue());
+        patch.addProperty("logMaxFileSizeMb",       parseInt(logMaxSizeField, "Log max file size", 1, 1000));
+        patch.addProperty("logMaxFileCount",        parseInt(logMaxCountField, "Log max file count", 1, 100));
+        patch.addProperty("schedulerThreadPoolSize",parseInt(schedulerPoolField, "Scheduler pool size", 1, 64));
+        patch.addProperty("heartbeatIntervalSeconds",parseInt(heartbeatField, "Heartbeat interval", 0, 3600));
+        patch.addProperty("sshConnectTimeoutMs",    parseInt(sshTimeoutField, "SSH connect timeout", 100, 120_000));
+        patch.addProperty("sftpChannelTimeoutMs",   parseInt(sftpTimeoutField, "SFTP channel timeout", 100, 60_000));
+
+        return patch;
+    }
+
+    private int parseInt(TextField field, String label, int min, int max) {
+        String raw = field.getText().trim();
+        try {
+            int val = Integer.parseInt(raw);
+            if (val < min || val > max)
+                throw new IllegalArgumentException(label + " must be between " + min + " and " + max + " (got " + val + ")");
+            return val;
+        } catch (NumberFormatException e) {
+            throw new IllegalArgumentException(label + " must be a whole number (got \"" + raw + "\")");
+        }
+    }
+
+    // ── Layout helpers ────────────────────────────────────────────────────────
+
+    private Label pageTitle(String text) {
+        Label l = new Label(text);
+        l.setStyle(
+                "-fx-font-size: 18;" +
+                "-fx-font-weight: bold;" +
+                "-fx-text-fill: " + Theme.TEXT_PRIMARY + ";" +
+                "-fx-padding: 0 0 4 0;");
+        return l;
+    }
+
+    private Label subtitle(String text) {
+        Label l = new Label(text);
+        l.setStyle(
+                "-fx-font-size: 11;" +
+                "-fx-text-fill: " + Theme.TEXT_MUTED + ";" +
+                "-fx-padding: 0 0 18 0;");
+        return l;
+    }
+
+    private Label section(String title) {
+        Label l = new Label(title.toUpperCase());
+        l.setStyle(
+                "-fx-font-size: 10;" +
+                "-fx-font-weight: bold;" +
+                "-fx-text-fill: " + Theme.TEXT_MUTED + ";" +
+                "-fx-letter-spacing: 0.08em;" +
+                "-fx-padding: 20 0 6 0;");
+        VBox.setMargin(l, new Insets(4, 0, 0, 0));
+        return l;
+    }
+
+    private HBox row(String label, javafx.scene.Node control, String hint) {
+        Label lbl = new Label(label);
+        lbl.setMinWidth(220);
+        lbl.setStyle("-fx-text-fill: " + Theme.TEXT_PRIMARY + "; -fx-font-size: 12;");
+
+        Label hintLabel = new Label(hint);
+        hintLabel.setStyle("-fx-text-fill: " + Theme.TEXT_MUTED + "; -fx-font-size: 10;");
+        hintLabel.setWrapText(true);
+
+        VBox rightCol = new VBox(4, control, hintLabel);
+        rightCol.setAlignment(Pos.TOP_LEFT);
+        HBox.setHgrow(rightCol, Priority.ALWAYS);
+
+        if (control instanceof TextField tf) {
+            tf.setPrefWidth(280);
+            tf.setMaxWidth(320);
+        } else if (control instanceof ComboBox<?> cb) {
+            cb.setPrefWidth(180);
+        }
+
+        HBox row = new HBox(16, lbl, rightCol);
+        row.setAlignment(Pos.CENTER_LEFT);
+        row.setPadding(new Insets(8, 0, 8, 0));
+        row.setStyle(
+                "-fx-background-color: transparent;" +
+                "-fx-border-color: transparent transparent " + Theme.BORDER + " transparent;" +
+                "-fx-border-width: 0 0 1 0;");
+        return row;
+    }
+
+    private HBox buildActions() {
+        statusLabel.setStyle("-fx-font-size: 11;");
+        statusLabel.setText("");
+
+        Region spacer = new Region();

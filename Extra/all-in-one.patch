+        if (patch.has("maxConcurrentTransfers"))
+            config.maxConcurrentTransfers = patch.get("maxConcurrentTransfers").getAsInt();
+
+        ConfigLoader.save(config);
+        LOG.info("Configuration updated via UPDATE_CONFIGURATION: " + config);
+    }
